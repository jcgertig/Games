{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat /dev/stdin | /Users/jonathan.gertig/Documents/Claude/Projects/Games/.claude/check-migration-immutable.sh",
            "timeout": 10,
            "statusMessage": "Checking migration immutability…"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat /dev/stdin | /Users/jonathan.gertig/Documents/Claude/Projects/Games/.claude/check-build.sh",
            "timeout": 120,
            "statusMessage": "Verifying build before commit…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat /dev/stdin | /Users/jonathan.gertig/Documents/Claude/Projects/Games/.claude/check-coverage.sh",
            "timeout": 120,
            "statusMessage": "Checking test coverage…",
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
